DATABASE_URL="postgresql://rumbo:rumbo@localhost:5432/rumbo"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production-refresh"
SMTP_HOST="localhost"
SMTP_PORT=1025
PORT=4000
CLIENT_URL="http://localhost:5173"

# AI Assistant (OpenRouter). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Primary model. owl-alpha is free and supports tool calling + 1M context.
OPENROUTER_MODEL="openrouter/owl-alpha"
# Optional: retried once if the primary model request fails. e.g. openai/gpt-oss-120b
OPENROUTER_FALLBACK_MODEL=""

# Encrypts third-party OAuth tokens (Connection model) at rest. Generate with:
# openssl rand -base64 32
CONNECTION_ENC_KEY=""

# Spotify connection (Settings > Connections). Create an app at
# https://developer.spotify.com/dashboard and set its redirect URI to match
# SPOTIFY_REDIRECT_URI below (points at this server, not the client). Leave
# SPOTIFY_CLIENT_ID/SECRET empty to keep the feature inert.
#
# Spotify rejects "localhost" as a redirect URI — it must be the literal loopback
# IP 127.0.0.1. Because of this, CLIENT_URL above must ALSO use 127.0.0.1 (not
# localhost) and you must open the app at http://127.0.0.1:5173 in the browser:
# the OAuth CSRF cookie set during /authorize is scoped to whichever hostname the
# browser was on, and it has to match the hostname Spotify redirects back to.
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://127.0.0.1:4000/api/connections/spotify/callback"

# Google Calendar connection (Settings > Connections). Create an OAuth client at
# https://console.cloud.google.com/apis/credentials (enable the "Google Calendar API"
# for the project first), configure the OAuth consent screen with the
# https://www.googleapis.com/auth/calendar.events scope, and set an Authorized redirect
# URI matching GOOGLE_REDIRECT_URI below. Leave CLIENT_ID/SECRET empty to keep the
# feature inert. Unlike Spotify, Google has no localhost/loopback-IP restriction.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://127.0.0.1:4000/api/connections/google/callback"
